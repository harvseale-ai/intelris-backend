generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Assistant {
  id          String   @id @default(uuid())
  assistantId String   @unique @map("assistant_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

model Party {
  id            Int      @id @default(autoincrement())
  partyId       Int      @unique @map("party_id")
  name          String   @map("name")
  isCommons     Boolean  @default(false)
  isLords       Boolean  @default(false)
  isIndependent Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  politicians   Politician[]

  @@map("parties")
}

enum ClassificationType {
  TAG
  TOPIC
  SECTION
  REGION
  DEPARTMENT
}

model ClassificationItem {
  id          Int                @id @default(autoincrement())
  externalId  Int                @unique
  type        ClassificationType
  title       String
  description String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @default(now()) @updatedAt

  politicianTopics       PoliticianTopic[]
  politicianSections     PoliticianSection[]
  politicianRegions      PoliticianRegion[]
  politicianDepartments  PoliticianDepartment[]

  politicianNewsTopics       PoliticianNewsTopic[]
  politicianNewsSections     PoliticianNewsSection[]
  politicianNewsRegions      PoliticianNewsRegion[]
  politicianNewsDepartments  PoliticianNewsDepartment[]

  politicalEventTopics       PoliticalEventTopic[]
  politicalEventSections     PoliticalEventSection[]
  politicalEventRegions      PoliticalEventRegion[]
  politicalEventDepartments  PoliticalEventDepartment[]

  newsTopics       NewsTopic[]
  newsSections     NewsSection[]
  newsRegions      NewsRegion[]
  newsDepartments  NewsDepartment[]

  @@map("classification_items")
  @@index([type])
}

model Politician {
  id                  Int       @id @default(autoincrement())
  politicianId        Int       @unique @map("politician_id")
  nameDisplayAs       String    @map("name_display_as")
  nameFullTitle       String    @map("name_full_title")
  gender              String?
  membershipFromId    Int?      @map("membership_from_id")
  membershipFrom      String?   @map("membership_from")
  houseId             Int?      @map("house_id")
  membershipStartDate DateTime? @map("membership_start_date")
  latestPartyId       Int?      @map("latest_party_id")
  thumbnailUrl        String?   @map("thumbnail_url")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")

  party               Party?    @relation(fields: [latestPartyId], references: [partyId])
  topics              PoliticianTopic[]
  sections            PoliticianSection[]
  regions             PoliticianRegion[]
  departments         PoliticianDepartment[]
  politicalEvents     PoliticalEvent[]

  @@map("politicians")
  @@index([latestPartyId])
}

model PoliticianTopic {
  politicianId         Int                @map("politician_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politician           Politician         @relation(fields: [politicianId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicianId, classificationItemId])
  @@map("politician_topics")
}

model PoliticianSection {
  politicianId         Int                @map("politician_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politician           Politician         @relation(fields: [politicianId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicianId, classificationItemId])
  @@map("politician_sections")
}

model PoliticianRegion {
  politicianId         Int                @map("politician_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politician           Politician         @relation(fields: [politicianId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicianId, classificationItemId])
  @@map("politician_regions")
}

model PoliticianDepartment {
  politicianId         Int                @map("politician_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politician           Politician         @relation(fields: [politicianId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicianId, classificationItemId])
  @@map("politician_departments")
}

model PoliticianNews {
  id         Int      @id @default(autoincrement())
  externalId Int      @unique @map("external_id")
  action     String
  summary    String
  payload    Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  topics      PoliticianNewsTopic[]
  sections    PoliticianNewsSection[]
  regions     PoliticianNewsRegion[]
  departments PoliticianNewsDepartment[]

  @@map("politician_news")
}

model PoliticianNewsTopic {
  politicianNewsId     Int                @map("politician_news_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politicianNews       PoliticianNews     @relation(fields: [politicianNewsId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicianNewsId, classificationItemId])
  @@map("politician_news_topics")
}

model PoliticianNewsSection {
  politicianNewsId     Int                @map("politician_news_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politicianNews       PoliticianNews     @relation(fields: [politicianNewsId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicianNewsId, classificationItemId])
  @@map("politician_news_sections")
}

model PoliticianNewsRegion {
  politicianNewsId     Int                @map("politician_news_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politicianNews       PoliticianNews     @relation(fields: [politicianNewsId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicianNewsId, classificationItemId])
  @@map("politician_news_regions")
}

model PoliticianNewsDepartment {
  politicianNewsId     Int                @map("politician_news_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politicianNews       PoliticianNews     @relation(fields: [politicianNewsId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicianNewsId, classificationItemId])
  @@map("politician_news_departments")
}

model News {
  id              Int      @id @default(autoincrement())
  externalId      String   @unique @map("external_id")
  title           String
  description     String
  summary         String
  publicTimestamp String   @map("public_timestamp")
  link            String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  topics          NewsTopic[]
  sections        NewsSection[]
  regions         NewsRegion[]
  departments     NewsDepartment[]

  @@map("news")
}

model NewsTopic {
  newsId               Int                @map("news_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  news                 News               @relation(fields: [newsId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([newsId, classificationItemId])
  @@map("news_topics")
}

model NewsSection {
  newsId               Int                @map("news_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  news                 News               @relation(fields: [newsId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([newsId, classificationItemId])
  @@map("news_sections")
}

model NewsRegion {
  newsId               Int                @map("news_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  news                 News               @relation(fields: [newsId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([newsId, classificationItemId])
  @@map("news_regions")
}

model NewsDepartment {
  newsId               Int                @map("news_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  news                 News               @relation(fields: [newsId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([newsId, classificationItemId])
  @@map("news_departments")
}

enum PoliticalEventType {
  ORAL_QUESTION
  WRITTEN_QUESTION
  WRITTEN_STATEMENT
  EARLY_DAY_MOTION
}

model PoliticalEvent {
  id               Int                @id @default(autoincrement())
  externalId       String             @map("external_id")
  eventType        PoliticalEventType @map("event_type")
  politicianId     Int?               @map("politician_id")
  title            String?
  summary          String?
  description      String?
  eventDate        DateTime?          @map("event_date")
  house            String?
  sourceSystem     String?            @map("source_system")
  payload          Json
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @default(now()) @updatedAt @map("updated_at")

  politician       Politician?        @relation(fields: [politicianId], references: [id], onDelete: SetNull)

  topics           PoliticalEventTopic[]
  sections         PoliticalEventSection[]
  regions          PoliticalEventRegion[]
  departments      PoliticalEventDepartment[]

  @@unique([externalId, eventType])
  @@map("political_events")
  @@index([politicianId])
  @@index([eventType])
  @@index([eventDate])
}

model PoliticalEventTopic {
  politicalEventId     Int                @map("political_event_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politicalEvent       PoliticalEvent     @relation(fields: [politicalEventId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicalEventId, classificationItemId])
  @@map("political_event_topics")
}

model PoliticalEventSection {
  politicalEventId     Int                @map("political_event_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politicalEvent       PoliticalEvent     @relation(fields: [politicalEventId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicalEventId, classificationItemId])
  @@map("political_event_sections")
}

model PoliticalEventRegion {
  politicalEventId     Int                @map("political_event_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politicalEvent       PoliticalEvent     @relation(fields: [politicalEventId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicalEventId, classificationItemId])
  @@map("political_event_regions")
}

model PoliticalEventDepartment {
  politicalEventId     Int                @map("political_event_id")
  classificationItemId Int                @map("classification_item_id")
  createdAt            DateTime           @default(now()) @map("created_at")

  politicalEvent       PoliticalEvent     @relation(fields: [politicalEventId], references: [id], onDelete: Cascade)
  classificationItem   ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@id([politicalEventId, classificationItemId])
  @@map("political_event_departments")
}
