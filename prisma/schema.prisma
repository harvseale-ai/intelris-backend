generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClassificationType {
  TAG
  TOPIC
  SECTION
  REGION
  DEPARTMENT
}

enum EntityType {
  PERSON
  ORGANISATION
  COMMITTEE
  PARTY
  BILL
  EVENT
  NEWS
  PUBLICATION
  PETITION
  OTHER
}

enum ImportanceLabel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChangeType {
  NEW
  UPDATED
  RECLASSIFIED
  RELATION_ADDED
  RELATION_REMOVED
  STAGE_MOVED
  STATUS_CHANGED
}

enum SourceMethod {
  AI
  RULE
  IMPORT
  MANUAL
  API
}

enum PoliticalEventType {
  ORAL_QUESTION
  WRITTEN_QUESTION
  WRITTEN_STATEMENT
  EARLY_DAY_MOTION
  COMMITTEE_HEARING
  DEBATE
  MEETING
  OTHER
}

model Assistant {
  id          String   @id @default(uuid())
  assistantId String   @unique @map("assistant_id")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("assistants")
}

model ClassificationItem {
  id            Int                 @id @default(autoincrement())
  externalId    Int?                @unique @map("external_id")
  type          ClassificationType
  slug          String?             @unique
  title         String
  description   String?
  includesText  String?             @map("includes_text")
  signalsText   String?             @map("signals_text")
  excludesText  String?             @map("excludes_text")
  isActive      Boolean             @default(true) @map("is_active")
  sortOrder     Int?                @map("sort_order")
  monitorWeight Float?              @map("monitor_weight")
  parentId      Int?                @map("parent_id")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  parent                    ClassificationItem?         @relation("ClassificationHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children                  ClassificationItem[]        @relation("ClassificationHierarchy")
  entityClassifications     EntityClassification[]
  relationshipClassifications RelationshipClassification[]

  @@map("classification_items")
  @@index([type])
  @@index([isActive])
  @@index([parentId])
}

model OrganisationType {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  label       String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  organisations Organisation[]

  @@map("organisation_types")
}

model CommitteeType {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  label       String
  description String?
  house       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  committees Committee[]

  @@map("committee_types")
}

model BillStageType {
  id         Int      @id @default(autoincrement())
  externalId String?  @unique @map("external_id")
  name       String
  house      String?
  sequence   Int?
  isTerminal Boolean  @default(false) @map("is_terminal")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  billStageOccurrences BillStageOccurrence[]

  @@map("bill_stage_types")
  @@index([house])
  @@index([sequence])
}

model RelationshipType {
  id                Int        @id @default(autoincrement())
  code              String     @unique
  label             String
  inverseLabel      String?    @map("inverse_label")
  subjectEntityType EntityType? @map("subject_entity_type")
  objectEntityType  EntityType? @map("object_entity_type")
  isDirectional     Boolean    @default(true) @map("is_directional")
  isActive          Boolean    @default(true) @map("is_active")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  entityRelationships EntityRelationship[]

  @@map("relationship_types")
}

model Entity {
  id                 Int        @id @default(autoincrement())
  entityType         EntityType @map("entity_type")
  displayName        String     @map("display_name")
  normalizedName     String     @map("normalized_name")
  slug               String?    @unique
  status             String?
  summary            String?
  description        String?
  primaryCountryCode String?    @map("primary_country_code")
  primaryRegionCode  String?    @map("primary_region_code")
  isActive           Boolean    @default(true) @map("is_active")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  person        Person?
  politician    PoliticianProfile?
  organisation  Organisation?
  committee     Committee?
  party         Party?
  bill          Bill?
  event         Event?
  news          News?
  publication   Publication?
  petition      Petition?

  subjectRelationships EntityRelationship[] @relation("EntityRelationshipSubject")
  objectRelationships  EntityRelationship[] @relation("EntityRelationshipObject")

  aliases          EntityAlias[]
  externalMappings ExternalMapping[]
  classifications  EntityClassification[]
  mentions         EntityMention[]
  statusHistory    EntityStatusHistory[]

  @@map("entities")
  @@index([entityType])
  @@index([displayName])
  @@index([normalizedName])
  @@index([status])
  @@index([isActive])
}

model Party {
  id            Int      @id @default(autoincrement())
  entityId      Int      @unique @map("entity_id")
  partyId       Int?     @unique @map("party_id")
  name          String   @map("name")
  slug          String?  @unique
  shortName     String?  @map("short_name")
  displayName   String?  @map("display_name")
  colourHex     String?  @map("colour_hex")
  houseScope    String?  @map("house_scope")
  isActive      Boolean  @default(true) @map("is_active")
  isCommons     Boolean  @default(false) @map("is_commons")
  isLords       Boolean  @default(false) @map("is_lords")
  isIndependent Boolean  @default(false) @map("is_independent")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  entity                Entity                      @relation(fields: [entityId], references: [id], onDelete: Cascade)
  politicianProfiles    PoliticianProfile[]
  politicianMemberships PoliticianPartyMembership[]

  @@map("parties")
  @@index([isActive])
}

model Person {
  id            Int       @id @default(autoincrement())
  entityId      Int       @unique @map("entity_id")
  externalId    String?   @unique @map("external_id")
  fullName      String    @map("full_name")
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  honorific     String?
  gender        String?
  dateOfBirth   DateTime? @map("date_of_birth")
  bio           String?
  thumbnailUrl  String?   @map("thumbnail_url")
  sourceSystem  String?   @map("source_system")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  entity               Entity                    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  politicianProfile    PoliticianProfile?
  organisationRoles    PersonOrganisationRole[]
  committeeRoles       PoliticianCommitteeRole[]
  billRelationships    BillPersonRelationship[]

  @@map("people")
  @@index([fullName])
  @@index([sourceSystem])
}

model PoliticianProfile {
  id                   Int       @id @default(autoincrement())
  entityId             Int       @unique @map("entity_id")
  personId             Int       @unique @map("person_id")
  politicianExternalId Int?      @unique @map("politician_external_id")
  house                String?
  membershipFrom       String?   @map("membership_from")
  membershipFromId     Int?      @map("membership_from_id")
  membershipStartDate  DateTime? @map("membership_start_date")
  currentPartyId       Int?      @map("current_party_id")
  currentConstituency  String?   @map("current_constituency")
  parliamentProfileUrl String?   @map("parliament_profile_url")
  currentRoleTitle     String?   @map("current_role_title")
  influenceScore       Float?    @map("influence_score")
  visibilityScore      Float?    @map("visibility_score")
  monitorWeight        Float?    @map("monitor_weight")
  isCurrent            Boolean   @default(true) @map("is_current")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  entity       Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  person       Person @relation(fields: [personId], references: [id], onDelete: Cascade)
  currentParty Party? @relation(fields: [currentPartyId], references: [id], onDelete: SetNull)

  @@map("politician_profiles")
  @@index([currentPartyId])
  @@index([isCurrent])
}

model Organisation {
  id                  Int      @id @default(autoincrement())
  entityId            Int      @unique @map("entity_id")
  externalId          String?  @unique @map("external_id")
  name                String
  normalizedName      String   @map("normalized_name")
  organisationTypeId  Int?     @map("organisation_type_id")
  website             String?
  countryCode         String?  @map("country_code")
  description         String?
  isGovernmentBody    Boolean  @default(false) @map("is_government_body")
  isParliamentaryBody Boolean  @default(false) @map("is_parliamentary_body")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  entity               Entity                 @relation(fields: [entityId], references: [id], onDelete: Cascade)
  organisationType     OrganisationType?      @relation(fields: [organisationTypeId], references: [id], onDelete: SetNull)
  personRoles          PersonOrganisationRole[]
  billRelationships    BillOrganisationRelationship[]

  @@map("organisations")
  @@index([organisationTypeId])
  @@index([normalizedName])
  @@index([countryCode])
  @@index([isActive])
}

model Committee {
  id              Int      @id @default(autoincrement())
  entityId        Int      @unique @map("entity_id")
  externalId      String?  @unique @map("external_id")
  name            String
  committeeTypeId Int?     @map("committee_type_id")
  house           String?
  description     String?
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  entity            Entity                     @relation(fields: [entityId], references: [id], onDelete: Cascade)
  committeeType     CommitteeType?             @relation(fields: [committeeTypeId], references: [id], onDelete: SetNull)
  politicianRoles   PoliticianCommitteeRole[]
  billRelationships BillCommitteeRelationship[]

  @@map("committees")
  @@index([committeeTypeId])
  @@index([house])
  @@index([isActive])
}

model Bill {
  id                       Int       @id @default(autoincrement())
  entityId                 Int       @unique @map("entity_id")
  externalId               String    @unique @map("external_id")
  title                    String
  shortTitle               String?   @map("short_title")
  billType                 String?   @map("bill_type")
  session                  String?
  house                    String?
  originatingHouse         String?   @map("originating_house")
  summary                  String?
  description              String?
  introducedAt             DateTime? @map("introduced_at")
  currentStageOccurrenceId Int?      @unique @map("current_stage_occurrence_id")
  isActive                 Boolean   @default(true) @map("is_active")
  lastApiUpdatedAt         DateTime? @map("last_api_updated_at")
  relevanceScore           Float?    @map("relevance_score")
  priorityScore            Float?    @map("priority_score")
  impactScore              Float?    @map("impact_score")
  monitorMatchScore        Float?    @map("monitor_match_score")
  confidenceScore          Float?    @map("confidence_score")
  importanceLabel          ImportanceLabel? @map("importance_label")
  briefSummary             String?   @map("brief_summary")
  clientImpactSummary      String?   @map("client_impact_summary")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  entity                    Entity                       @relation(fields: [entityId], references: [id], onDelete: Cascade)
  currentStageOccurrence    BillStageOccurrence?         @relation("BillCurrentStage", fields: [currentStageOccurrenceId], references: [id], onDelete: SetNull)
  stageOccurrences          BillStageOccurrence[]        @relation("BillStageOccurrences")
  committeeRelationships    BillCommitteeRelationship[]
  personRelationships       BillPersonRelationship[]
  organisationRelationships BillOrganisationRelationship[]
  eventRelationships        EventBillRelationship[]

  @@map("bills")
  @@index([billType])
  @@index([session])
  @@index([house])
  @@index([isActive])
  @@index([introducedAt])
  @@index([importanceLabel])
}

model Event {
  id                  Int                @id @default(autoincrement())
  entityId            Int                @unique @map("entity_id")
  externalId          String?            @unique @map("external_id")
  eventType           String             @map("event_type")
  politicalEventType  PoliticalEventType? @map("political_event_type")
  title               String
  summary             String?
  description         String?
  startsAt            DateTime?          @map("starts_at")
  endsAt              DateTime?          @map("ends_at")
  location            String?
  status              String?
  sourceSystem        String?            @map("source_system")
  sourceUrl           String?            @map("source_url")
  sourceExternalId    String?            @map("source_external_id")
  fetchedAt           DateTime?          @map("fetched_at")
  firstSeenAt         DateTime?          @map("first_seen_at")
  lastSeenAt          DateTime?          @map("last_seen_at")
  lastProcessedAt     DateTime?          @map("last_processed_at")
  relevanceScore      Float?             @map("relevance_score")
  priorityScore       Float?             @map("priority_score")
  signalScore         Float?             @map("signal_score")
  impactScore         Float?             @map("impact_score")
  monitorMatchScore   Float?             @map("monitor_match_score")
  confidenceScore     Float?             @map("confidence_score")
  importanceLabel     ImportanceLabel?   @map("importance_label")
  isKeyUpdate         Boolean            @default(false) @map("is_key_update")
  whyRelevant         String?            @map("why_relevant")
  briefSummary        String?            @map("brief_summary")
  clientImpactSummary String?            @map("client_impact_summary")
  changeType          ChangeType?        @map("change_type")
  changeSummary       String?            @map("change_summary")
  contentHash         String?            @map("content_hash")
  changeHash          String?            @map("change_hash")
  payload             Json?
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  entity        Entity                 @relation(fields: [entityId], references: [id], onDelete: Cascade)
  participants  EventParticipant[]
  billRelations EventBillRelationship[]

  @@map("events")
  @@index([eventType])
  @@index([politicalEventType])
  @@index([startsAt])
  @@index([endsAt])
  @@index([status])
  @@index([sourceSystem])
  @@index([importanceLabel])
}

model News {
  id                  Int               @id @default(autoincrement())
  entityId            Int               @unique @map("entity_id")
  externalId          String            @unique @map("external_id")
  title               String
  description         String?
  summary             String?
  publicTimestamp     String?           @map("public_timestamp")
  link                String?
  publishedAt         DateTime?         @map("published_at")
  sourceSystem        String?           @map("source_system")
  sourceUrl           String?           @map("source_url")
  sourceExternalId    String?           @map("source_external_id")
  fetchedAt           DateTime?         @map("fetched_at")
  firstSeenAt         DateTime?         @map("first_seen_at")
  lastSeenAt          DateTime?         @map("last_seen_at")
  lastProcessedAt     DateTime?         @map("last_processed_at")
  relevanceScore      Float?            @map("relevance_score")
  priorityScore       Float?            @map("priority_score")
  signalScore         Float?            @map("signal_score")
  impactScore         Float?            @map("impact_score")
  monitorMatchScore   Float?            @map("monitor_match_score")
  confidenceScore     Float?            @map("confidence_score")
  importanceLabel     ImportanceLabel?  @map("importance_label")
  isKeyUpdate         Boolean           @default(false) @map("is_key_update")
  whyRelevant         String?           @map("why_relevant")
  briefSummary        String?           @map("brief_summary")
  clientImpactSummary String?           @map("client_impact_summary")
  changeType          ChangeType?       @map("change_type")
  changeSummary       String?           @map("change_summary")
  contentHash         String?           @map("content_hash")
  changeHash          String?           @map("change_hash")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("news")
  @@index([publishedAt])
  @@index([sourceSystem])
  @@index([firstSeenAt])
  @@index([lastSeenAt])
  @@index([relevanceScore])
  @@index([priorityScore])
  @@index([monitorMatchScore])
  @@index([importanceLabel])
  @@index([changeType])
  @@index([isKeyUpdate])
}

model Publication {
  id                  Int               @id @default(autoincrement())
  entityId            Int               @unique @map("entity_id")
  externalId          String            @unique @map("external_id")
  publicationType     String?           @map("publication_type")
  title               String
  summary             String?
  description         String?
  publishedAt         DateTime?         @map("published_at")
  url                 String?
  sourceSystem        String?           @map("source_system")
  sourceUrl           String?           @map("source_url")
  sourceExternalId    String?           @map("source_external_id")
  fetchedAt           DateTime?         @map("fetched_at")
  firstSeenAt         DateTime?         @map("first_seen_at")
  lastSeenAt          DateTime?         @map("last_seen_at")
  lastProcessedAt     DateTime?         @map("last_processed_at")
  relevanceScore      Float?            @map("relevance_score")
  priorityScore       Float?            @map("priority_score")
  signalScore         Float?            @map("signal_score")
  impactScore         Float?            @map("impact_score")
  monitorMatchScore   Float?            @map("monitor_match_score")
  confidenceScore     Float?            @map("confidence_score")
  importanceLabel     ImportanceLabel?  @map("importance_label")
  isKeyUpdate         Boolean           @default(false) @map("is_key_update")
  whyRelevant         String?           @map("why_relevant")
  briefSummary        String?           @map("brief_summary")
  clientImpactSummary String?           @map("client_impact_summary")
  changeType          ChangeType?       @map("change_type")
  changeSummary       String?           @map("change_summary")
  contentHash         String?           @map("content_hash")
  changeHash          String?           @map("change_hash")
  payload             Json?
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("publications")
  @@index([publicationType])
  @@index([publishedAt])
  @@index([sourceSystem])
  @@index([importanceLabel])
}

model Petition {
  id                  Int               @id @default(autoincrement())
  entityId            Int               @unique @map("entity_id")
  externalId          String            @unique @map("external_id")
  title               String
  summary             String?
  description         String?
  petitionState       String?           @map("petition_state")
  openedAt            DateTime?         @map("opened_at")
  closedAt            DateTime?         @map("closed_at")
  signatureCount      Int?              @map("signature_count")
  url                 String?
  sourceSystem        String?           @map("source_system")
  relevanceScore      Float?            @map("relevance_score")
  priorityScore       Float?            @map("priority_score")
  monitorMatchScore   Float?            @map("monitor_match_score")
  confidenceScore     Float?            @map("confidence_score")
  importanceLabel     ImportanceLabel?  @map("importance_label")
  briefSummary        String?           @map("brief_summary")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("petitions")
  @@index([petitionState])
  @@index([openedAt])
  @@index([closedAt])
  @@index([importanceLabel])
}

model EntityRelationship {
  id                 Int       @id @default(autoincrement())
  subjectEntityId    Int       @map("subject_entity_id")
  relationshipTypeId Int       @map("relationship_type_id")
  objectEntityId     Int       @map("object_entity_id")
  status             String?
  isCurrent          Boolean   @default(true) @map("is_current")
  startDate          DateTime? @map("start_date")
  endDate            DateTime? @map("end_date")
  strengthScore      Float?    @map("strength_score")
  confidenceScore    Float?    @map("confidence_score")
  sourceOfTruth      String?   @map("source_of_truth")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  subjectEntity    Entity           @relation("EntityRelationshipSubject", fields: [subjectEntityId], references: [id], onDelete: Cascade)
  relationshipType RelationshipType @relation(fields: [relationshipTypeId], references: [id], onDelete: Restrict)
  objectEntity     Entity           @relation("EntityRelationshipObject", fields: [objectEntityId], references: [id], onDelete: Cascade)

  classifications RelationshipClassification[]
  evidence        RelationshipEvidence[]

  @@map("entity_relationships")
  @@index([subjectEntityId])
  @@index([objectEntityId])
  @@index([relationshipTypeId])
  @@index([isCurrent])
  @@index([status])
}

model PersonOrganisationRole {
  id               Int       @id @default(autoincrement())
  personId         Int       @map("person_id")
  organisationId   Int       @map("organisation_id")
  roleTitle        String    @map("role_title")
  roleType         String?   @map("role_type")
  seniority        String?
  isCurrent        Boolean   @default(true) @map("is_current")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  sourceSystem     String?   @map("source_system")
  sourceExternalId String?   @map("source_external_id")
  lastVerifiedAt   DateTime? @map("last_verified_at")
  confidenceScore  Float?    @map("confidence_score")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  person       Person       @relation(fields: [personId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@map("person_organisation_roles")
  @@index([personId])
  @@index([organisationId])
  @@index([isCurrent])
  @@index([roleTitle])
}

model PoliticianPartyMembership {
  id           Int       @id @default(autoincrement())
  politicianId Int       @map("politician_id")
  partyId      Int       @map("party_id")
  house        String?
  isCurrent    Boolean   @default(true) @map("is_current")
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  sourceSystem String?   @map("source_system")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  politician PoliticianProfile @relation(fields: [politicianId], references: [id], onDelete: Cascade)
  party      Party             @relation(fields: [partyId], references: [id], onDelete: Cascade)

  @@map("politician_party_memberships")
  @@index([politicianId])
  @@index([partyId])
  @@index([isCurrent])
}

model PoliticianCommitteeRole {
  id           Int       @id @default(autoincrement())
  politicianId Int       @map("politician_id")
  committeeId  Int       @map("committee_id")
  roleTitle    String?   @map("role_title")
  isCurrent    Boolean   @default(true) @map("is_current")
  startDate    DateTime? @map("start_date")
  endDate      DateTime? @map("end_date")
  sourceSystem String?   @map("source_system")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  politician PoliticianProfile @relation(fields: [politicianId], references: [id], onDelete: Cascade)
  committee  Committee         @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@map("politician_committee_roles")
  @@index([politicianId])
  @@index([committeeId])
  @@index([isCurrent])
}

model BillCommitteeRelationship {
  id               Int       @id @default(autoincrement())
  billId           Int       @map("bill_id")
  committeeId      Int       @map("committee_id")
  relationshipKind String    @map("relationship_kind")
  isCurrent        Boolean   @default(true) @map("is_current")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  bill      Bill      @relation(fields: [billId], references: [id], onDelete: Cascade)
  committee Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)

  @@map("bill_committee_relationships")
  @@index([billId])
  @@index([committeeId])
  @@index([isCurrent])
  @@index([relationshipKind])
}

model BillPersonRelationship {
  id               Int       @id @default(autoincrement())
  billId           Int       @map("bill_id")
  personId         Int       @map("person_id")
  relationshipKind String    @map("relationship_kind")
  isCurrent        Boolean   @default(true) @map("is_current")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  bill   Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@map("bill_person_relationships")
  @@index([billId])
  @@index([personId])
  @@index([isCurrent])
  @@index([relationshipKind])
}

model BillOrganisationRelationship {
  id               Int       @id @default(autoincrement())
  billId           Int       @map("bill_id")
  organisationId   Int       @map("organisation_id")
  relationshipKind String    @map("relationship_kind")
  isCurrent        Boolean   @default(true) @map("is_current")
  startDate        DateTime? @map("start_date")
  endDate          DateTime? @map("end_date")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  bill         Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)
  organisation Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)

  @@map("bill_organisation_relationships")
  @@index([billId])
  @@index([organisationId])
  @@index([isCurrent])
  @@index([relationshipKind])
}

model EventParticipant {
  id               Int       @id @default(autoincrement())
  eventId          Int       @map("event_id")
  participantId    Int       @map("participant_id")
  participantType  EntityType? @map("participant_type")
  roleAtEvent      String?   @map("role_at_event")
  attendanceStatus String?   @map("attendance_status")
  isSpeaker        Boolean   @default(false) @map("is_speaker")
  isWitness        Boolean   @default(false) @map("is_witness")
  sourceSystem     String?   @map("source_system")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  event       Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  participant Entity @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@map("event_participants")
  @@index([eventId])
  @@index([participantId])
  @@index([participantType])
  @@index([isSpeaker])
  @@index([isWitness])
}

model EventBillRelationship {
  id               Int      @id @default(autoincrement())
  eventId          Int      @map("event_id")
  billId           Int      @map("bill_id")
  relationshipKind String?  @map("relationship_kind")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  bill  Bill  @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@map("event_bill_relationships")
  @@index([eventId])
  @@index([billId])
}

model BillStageOccurrence {
  id                 Int       @id @default(autoincrement())
  billId             Int       @map("bill_id")
  billStageTypeId    Int       @map("bill_stage_type_id")
  house              String?
  occurredAt         DateTime? @map("occurred_at")
  completedAt        DateTime? @map("completed_at")
  status             String?
  sequenceWithinBill Int?      @map("sequence_within_bill")
  sourceUrl          String?   @map("source_url")
  payload            Json?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  bill           Bill          @relation("BillStageOccurrences", fields: [billId], references: [id], onDelete: Cascade)
  billStageType  BillStageType @relation(fields: [billStageTypeId], references: [id], onDelete: Restrict)
  currentForBill Bill?         @relation("BillCurrentStage")

  @@map("bill_stage_occurrences")
  @@index([billId])
  @@index([billStageTypeId])
  @@index([status])
  @@index([occurredAt])
}

model EntityClassification {
  id                   Int          @id @default(autoincrement())
  entityId             Int          @map("entity_id")
  classificationItemId Int          @map("classification_item_id")
  sourceSystem         String?      @map("source_system")
  sourceMethod         SourceMethod? @map("source_method")
  confidenceScore      Float?       @map("confidence_score")
  isPrimary            Boolean      @default(false) @map("is_primary")
  createdAt            DateTime     @default(now()) @map("created_at")
  updatedAt            DateTime     @updatedAt @map("updated_at")

  entity             Entity             @relation(fields: [entityId], references: [id], onDelete: Cascade)
  classificationItem ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@map("entity_classifications")
  @@unique([entityId, classificationItemId])
  @@index([entityId])
  @@index([classificationItemId])
  @@index([isPrimary])
}

model RelationshipClassification {
  id                   Int       @id @default(autoincrement())
  entityRelationshipId Int       @map("entity_relationship_id")
  classificationItemId Int       @map("classification_item_id")
  confidenceScore      Float?    @map("confidence_score")
  isPrimary            Boolean   @default(false) @map("is_primary")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  entityRelationship EntityRelationship @relation(fields: [entityRelationshipId], references: [id], onDelete: Cascade)
  classificationItem ClassificationItem @relation(fields: [classificationItemId], references: [id], onDelete: Cascade)

  @@map("relationship_classifications")
  @@unique([entityRelationshipId, classificationItemId])
  @@index([entityRelationshipId])
  @@index([classificationItemId])
  @@index([isPrimary])
}

model SourceRecord {
  id                    Int       @id @default(autoincrement())
  sourceSystem          String    @map("source_system")
  externalId            String?   @map("external_id")
  recordType            String    @map("record_type")
  url                   String?
  title                 String?
  publishedAt           DateTime? @map("published_at")
  fetchedAt             DateTime? @map("fetched_at")
  rawPayload            Json?     @map("raw_payload")
  normalizedPayloadHash String?   @map("normalized_payload_hash")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  relationshipEvidence RelationshipEvidence[]
  entityMentions       EntityMention[]

  @@map("source_records")
  @@index([sourceSystem])
  @@index([recordType])
  @@index([publishedAt])
  @@index([externalId])
}

model RelationshipEvidence {
  id                   Int       @id @default(autoincrement())
  entityRelationshipId Int       @map("entity_relationship_id")
  sourceRecordId       Int       @map("source_record_id")
  evidenceType         String?   @map("evidence_type")
  excerpt              String?
  confidenceScore      Float?    @map("confidence_score")
  observedAt           DateTime? @map("observed_at")
  createdAt            DateTime  @default(now()) @map("created_at")

  entityRelationship EntityRelationship @relation(fields: [entityRelationshipId], references: [id], onDelete: Cascade)
  sourceRecord       SourceRecord       @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)

  @@map("relationship_evidence")
  @@index([entityRelationshipId])
  @@index([sourceRecordId])
  @@index([observedAt])
}

model EntityMention {
  id             Int      @id @default(autoincrement())
  sourceRecordId Int      @map("source_record_id")
  entityId       Int      @map("entity_id")
  mentionText    String   @map("mention_text")
  mentionType    String?  @map("mention_type")
  offsetStart    Int?     @map("offset_start")
  offsetEnd      Int?     @map("offset_end")
  createdAt      DateTime @default(now()) @map("created_at")

  sourceRecord SourceRecord @relation(fields: [sourceRecordId], references: [id], onDelete: Cascade)
  entity       Entity       @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("entity_mentions")
  @@index([sourceRecordId])
  @@index([entityId])
  @@index([mentionType])
}

model EntityAlias {
  id              Int      @id @default(autoincrement())
  entityId        Int      @map("entity_id")
  alias           String
  normalizedAlias String   @map("normalized_alias")
  aliasType       String?  @map("alias_type")
  sourceSystem    String?  @map("source_system")
  createdAt       DateTime @default(now()) @map("created_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("entity_aliases")
  @@index([entityId])
  @@index([normalizedAlias])
}

model ExternalMapping {
  id           Int      @id @default(autoincrement())
  entityId     Int      @map("entity_id")
  sourceSystem String   @map("source_system")
  externalId   String   @map("external_id")
  externalType String?  @map("external_type")
  isPrimary    Boolean  @default(false) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("external_mappings")
  @@unique([sourceSystem, externalId])
  @@index([entityId])
  @@index([sourceSystem])
  @@index([externalId])
}

model EntityStatusHistory {
  id            Int       @id @default(autoincrement())
  entityId      Int       @map("entity_id")
  status        String
  effectiveDate DateTime? @map("effective_date")
  sourceSystem  String?   @map("source_system")
  createdAt     DateTime  @default(now()) @map("created_at")

  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@map("entity_status_history")
  @@index([entityId])
  @@index([status])
  @@index([effectiveDate])
}

model ImportRun {
  id             Int       @id @default(autoincrement())
  sourceSystem   String    @map("source_system")
  jobName        String    @map("job_name")
  status         String
  startedAt      DateTime  @map("started_at")
  completedAt    DateTime? @map("completed_at")
  recordsFetched Int?      @map("records_fetched")
  recordsCreated Int?      @map("records_created")
  recordsUpdated Int?      @map("records_updated")
  recordsErrored Int?      @map("records_errored")
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("import_runs")
  @@index([sourceSystem])
  @@index([jobName])
  @@index([status])
  @@index([startedAt])
}
